class SearchProduct:
    def __init__(self, product_id: str, product_name: str, category: str):
        self.product_id = product_id
        self.product_name = product_name
        self.category = category

class PlatformSearch:
    def linear_search(products: list, target_id: str) -> SearchProduct:
        for product in products:
            if product.product_id == target_id:
                return product
        return None

    def binary_search(sorted_products: list, target_id: str) -> SearchProduct:
        left = 0
        right = len(sorted_products) - 1

        while left <= right:
            mid = left + (right - left) // 2
            mid_id = sorted_products[mid].product_id

            if mid_id == target_id:
                return sorted_products[mid]
            elif mid_id < target_id:
                left = mid + 1
            else:
                right = mid - 1
        return None