from abc import ABC, abstractmethod

class Image(ABC):
    @abstractmethod
    def display(self):
        pass

class RealImage(Image):
    def __init__(self, filename: str):
        self.filename = filename
        self._load_from_remote_server()

    def _load_from_remote_server(self):
        print(f"Executing heavy network operation: Downloading {self.filename}")

    def display(self):
        print(f"Rendering: {self.filename}")

class ProxyImage(Image):
    def __init__(self, filename: str):
        self.filename = filename
        self._real_image = None

    def display(self):
        if self._real_image is None:
            self._real_image = RealImage(self.filename)
        else:
            print(f"Cache Hit! Serving instant access pointer to {self.filename}")
        self._real_image.display()

if __name__ == "__main__":
    image = ProxyImage("high_res_photo.raw")
    print("--- First Call (Triggers lazy loading logic) ---")
    image.display()
    print("\n--- Second Call (Uses the cached reference) ---")
    image.display()
    